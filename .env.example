# --- CONFIGURACIÓN DE BASE DE DATOS (PLANTILLA) ---
# Copia este archivo como .env y rellena con tus datos locales

DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nombre_db

# URI de conexión completa
DATABASE_URL=postgresql://user:pass@host:port/db

# --- CONFIGURACIÓN DE RENDIMIENTO ---
DB_POOL_MAX=10
DB_SSL_MODE=disable